{
  "name": "domains-monit-backend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Domain purchase, provisioning and monitoring backend (Express + BullMQ + PostgreSQL)",
  "scripts": {
    "api": "tsx src/index.ts",
