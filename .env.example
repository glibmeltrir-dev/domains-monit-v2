# ---- Ports ----
FRONTEND_PORT=8080

# ---- PostgreSQL ----
POSTGRES_USER=domains
POSTGRES_PASSWORD=change_me
POSTGRES_DB=domains

# ---- Monitoring tuning ----
MONITOR_CONCURRENCY=20
PROVISION_CONCURRENCY=5
SCHEDULER_INTERVAL_SEC=30
MONITOR_DEFAULT_INTERVAL_SEC=300

# Target server all domains point their A-record to (Keitaro).
KEITARO_DEFAULT_IP=178.63.149.98
KEITARO_IP=178.63.149.98
KEITARO_URL=
KEITARO_API_KEY=

# ---- Namecheap (buying / nameservers) ----
NAMECHEAP_API_USER=your_api_user
NAMECHEAP_USERNAME=your_username
NAMECHEAP_API_KEY=your_api_key
# Whitelisted IP for the Namecheap API (your server's public IP).
NAMECHEAP_CLIENT_IP=
# WHOIS contact profile used when registering domains (JSON).
NAMECHEAP_CONTACT={"FirstName":"John","LastName":"Doe","Address1":"Street 1","City":"City","StateProvince":"State","PostalCode":"10001","Country":"US","Phone":"+1.6613102107","EmailAddress":"you@example.com"}

# ---- Cloudflare (connecting) ----
CLOUDFLARE_API_TOKEN=your_cf_token
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL=

# ---- Telegram (optional; can also be set in the UI) ----
TG_BOT_TOKEN=
TG_CHAT_IDS=
