# ---- Ports ----
FRONTEND_PORT=8080
# Host interface the panel binds to. Default 127.0.0.1 = localhost only (access
# via SSH tunnel), since the panel has no auth. Set to 0.0.0.0 to expose it.
FRONTEND_BIND=127.0.0.1

# ---- PostgreSQL ----
POSTGRES_USER=domains
POSTGRES_PASSWORD=change_me
POSTGRES_DB=domains

# ---- Monitoring tuning ----
MONITOR_CONCURRENCY=20
PROVISION_CONCURRENCY=5
SCHEDULER_INTERVAL_SEC=30
MONITOR_DEFAULT_INTERVAL_SEC=300

# Target server all domains point their A-record to (Keitaro).
KEITARO_DEFAULT_IP=178.63.149.98
KEITARO_IP=178.63.149.98
KEITARO_URL=
KEITARO_API_KEY=

# ---- Namecheap / Cloudflare / Keitaro / Telegram ----
# ВАЖНО: аккаунты интеграций добавляются в админке (страница «Интеграции»),
# а Telegram и Namecheap-контакт — на странице «Настройки».
# Переменные ниже НЕ обязательны: они используются ТОЛЬКО скриптом `seed`
# для первичного заполнения БД. В рантайме покупка/подключение/уведомления
# берут креды из базы. Оставь пустыми, если заполняешь всё через UI.

# Namecheap (buying / nameservers)
NAMECHEAP_API_USER=
NAMECHEAP_USERNAME=
NAMECHEAP_API_KEY=
# Whitelisted IP for the Namecheap API (your server's public IP).
NAMECHEAP_CLIENT_IP=
# WHOIS contact profile used when registering domains (JSON).
NAMECHEAP_CONTACT=

# Cloudflare (connecting)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL=

# Telegram (optional; can also be set in the UI)
TG_BOT_TOKEN=
TG_CHAT_IDS=
